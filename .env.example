# OpenAI (required)
OPENAI_API_KEY=sk-...
# Optional
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# WHO ICD-11 API (optional; register at https://icd.who.int/icdapi/Account/Register)
ICD_CLIENT_ID=
ICD_CLIENT_SECRET=
# Release segment in MMS search URL, e.g. 2024-01 (see WHO ICD API docs if search fails)
ICD_RELEASE_ID=2024-01
